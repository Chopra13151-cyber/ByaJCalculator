<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Interest Type Toggle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INTEREST TYPE"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp" />

        <RadioGroup
            android:id="@+id/rgInterestType"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/toggle_bg"
            android:padding="4dp"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbSimple"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Simple"
                android:checked="true"
                android:button="@null"
                android:gravity="center"
                android:textColor="@color/toggle_text_selector"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/toggle_item_selector" />

            <RadioButton
                android:id="@+id/rbCompound"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Compound"
                android:button="@null"
                android:gravity="center"
                android:textColor="@color/toggle_text_selector"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/toggle_item_selector" />
        </RadioGroup>

        <!-- Principal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRINCIPAL AMOUNT (₹)"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/InputLayoutStyle"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrincipal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="numberDecimal"
                android:hint="e.g. 100000"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Rate -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RATE OF INTEREST (% per annum)"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/InputLayoutStyle"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="numberDecimal"
                android:hint="e.g. 8.5"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Time + Unit -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIME PERIOD"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/InputLayoutStyle"
                android:layout_marginEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTime"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="numberDecimal"
                    android:hint="e.g. 3"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-light"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/input_bg"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <RadioGroup
                android:id="@+id/rgTimeUnit"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@drawable/toggle_bg"
                android:padding="4dp">

                <RadioButton
                    android:id="@+id/rbYears"
                    android:layout_width="72dp"
                    android:layout_height="match_parent"
                    android:text="Years"
                    android:checked="true"
                    android:button="@null"
                    android:gravity="center"
                    android:textColor="@color/toggle_text_selector"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/toggle_item_selector" />

                <RadioButton
                    android:id="@+id/rbMonths"
                    android:layout_width="72dp"
                    android:layout_height="match_parent"
                    android:text="Months"
                    android:button="@null"
                    android:gravity="center"
                    android:textColor="@color/toggle_text_selector"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/toggle_item_selector" />
            </RadioGroup>
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Reset"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/btn_secondary_bg"
                android:layout_marginEnd="12dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:text="Calculate Byaj"
                android:textColor="@color/bg_dark"
                android:textSize="15sp"
                android:fontFamily="sans-serif-bold"
                android:background="@drawable/btn_primary_bg"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Result Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvResultLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Simple Interest"
                    android:textColor="@color/accent_gold"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <!-- Interest Amount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Interest Earned"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvInterestAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ 0"
                        android:textColor="@color/accent_green"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginVertical="12dp" />

                <!-- Total Amount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Amount"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvTotalAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ 0"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Breakdown Card -->
        <LinearLayout
            android:id="@+id/layoutBreakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/breakdown_bg"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FORMULA USED"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvBreakdownFormula"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SI = (P × R × T) / 100"
                android:textColor="@color/accent_gold"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvBreakdownP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvBreakdownR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvBreakdownT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>