<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Base.Theme.ByajCalculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_gold</item>
        <item name="colorPrimaryVariant">@color/accent_gold_dim</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.ByajCalculator" parent="Base.Theme.ByajCalculator" />

    <!-- Calculator Buttons -->
    <style name="NumberButton">
        <item name="android:layout_height">72dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:background">@drawable/btn_number_bg</item>
        <item name="android:layout_marginLeft">5dp</item>
        <item name="android:layout_marginRight">5dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="FuncButton">
        <item name="android:layout_height">72dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">@drawable/btn_func_bg</item>
        <item name="android:layout_marginLeft">5dp</item>
        <item name="android:layout_marginRight">5dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="OperatorButton">
        <item name="android:layout_height">72dp</item>
        <item name="android:textColor">@color/accent_operator</item>
        <item name="android:textSize">26sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:background">@drawable/btn_operator_bg</item>
        <item name="android:layout_marginLeft">5dp</item>
        <item name="android:layout_marginRight">5dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="EqualsButton">
        <item name="android:layout_height">72dp</item>
        <item name="android:textColor">@color/bg_dark</item>
        <item name="android:textSize">26sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">@drawable/btn_equals_bg</item>
        <item name="android:layout_marginLeft">5dp</item>
        <item name="android:layout_marginRight">5dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Tab text -->
    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Input layout style -->
    <style name="InputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxBackgroundColor">@color/bg_surface</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

</resources>